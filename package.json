{
  "name": "naracli",
  "version": "1.0.31",
  "description": "CLI for the Nara chain (Solana-compatible)",
  "module": "index.ts",
  "main": "index.ts",
  "type": "module",
  "private": false,
  "bin": {
    "naracli": "./dist/naracli.cjs"
  },
  "scripts": {
    "cli": "node --require ./bin/env-loader.cjs --import tsx bin/nara-cli.ts",
    "build": "node scripts/build.cjs",
    "test": "node --require ./bin/env-loader.cjs --import tsx --test --experimental-test-isolation=none --test-reporter spec src/tests/quest.test.ts src/tests/skills.test.ts src/tests/zkid.test.ts src/tests/agent-registry.test.ts",
    "test:quest": "node --require ./bin/env-loader.cjs --import tsx --test --experimental-test-isolation=none --test-reporter spec src/tests/quest.test.ts",
    "test:skills": "node --require ./bin/env-loader.cjs --import tsx --test --experimental-test-isolation=none --test-reporter spec src/tests/skills.test.ts",
    "test:zkid": "node --require ./bin/env-loader.cjs --import tsx --test --experimental-test-isolation=none --test-reporter spec src/tests/zkid.test.ts",
    "test:agent": "node --require ./bin/env-loader.cjs --import tsx --test --experimental-test-isolation=none --test-reporter spec src/tests/agent-registry.test.ts",
    "test:quest-referral": "node --require ./bin/env-loader.cjs --import tsx --test --experimental-test-isolation=none --test-reporter spec src/tests/quest-referral.test.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "src",
    "index.ts",
    "bin"
  ],
  "keywords": [
    "nara",
    "solana",
    "blockchain",
    "cli",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/bn.js": "^5.2.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bip39": "^3.1.0",
    "bn.js": "^5.2.2",
    "bs58": "^6.0.0",
    "commander": "^12.1.0",
    "ed25519-hd-key": "^1.3.0",
    "nara-sdk": "^1.0.32",
    "picocolors": "^1.1.1"
  }
}
